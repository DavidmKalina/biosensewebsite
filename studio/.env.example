# Copy this file to ".env" and fill in the values.
# Find the project ID at https://sanity.io/manage (or in the project URL).
SANITY_STUDIO_PROJECT_ID=your_project_id_here
SANITY_STUDIO_DATASET=production

# Only needed to run the one-time content migration (npm run migrate).
# Create a token with "Editor" permissions at:
#   https://sanity.io/manage -> your project -> API -> Tokens
# Do NOT commit this value. studio/.env is gitignored.
SANITY_WRITE_TOKEN=your_editor_token_here
