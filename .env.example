VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production

# Optional. A read-only "Viewer" token (sanity.io/manage -> project -> API ->
# Tokens). Lets the site show unpublished drafts when preview mode is on
# (visit the site with ?preview=1). Without this set, the preview link does
# nothing and the site only ever shows published content.
# Note: this token ends up in the site's public JS bundle, since this is a
# static site with no server to keep it secret. Use a Viewer (read-only)
# token, never Editor/Admin. See SANITY_SETUP.md for details.
VITE_SANITY_PREVIEW_TOKEN=

# Only needed locally to run the one-time content migration script in
# studio/. Never commit a real value.
SANITY_WRITE_TOKEN=
